{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyMaxRetries": 5,
    "services": [
      {
        "name": "frontend",
        "path": "client",
        "buildCommand": "npm install && npm run build",
        "startCommand": "npx serve -s dist"
      },
      {
        "name": "backend",
        "path": "server",
        "buildCommand": "npm install",
        "startCommand": "node index.js"
      }
    ]
  }
}
